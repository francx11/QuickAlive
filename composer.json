{
    "require": {
        "php": "^8.4",
        "twig/twig": "^3.11.1",
        "phpmailer/phpmailer": "^6.9",
        "sunra/php-simple-html-dom-parser": "^1.5",
        "anthropic-ai/sdk": "^0.29.2",
        "symfony/http-client": "^7.4",
        "nyholm/psr7": "^1.8",
        "league/route": "^6.2",
        "php-di/php-di": "^7.1",
        "doctrine/dbal": "^4.4",
        "vlucas/phpdotenv": "^5.6",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "nyholm/psr7-server": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.50",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
